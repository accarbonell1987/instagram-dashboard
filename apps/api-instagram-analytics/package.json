    "@prisma/client": "^6.4.0",
    "dotenv": "^16.4.7",
    "hono": "^4.6.17",
    "jose": "^5.9.6",
    "openai": "^6.44.0",
    "sharp": "^0.35.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@core/config": "workspace:*",
    "@types/node": "^22.10.7",
    "@vitest/coverage-v8": "^3.0.5",
    "eslint": "^9.18.0",
    "prisma": "^6.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
