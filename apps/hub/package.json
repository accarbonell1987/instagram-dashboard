{
  "name": "@corehub/hub",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --turbopack --port 3001",
    "build": "next build",
    "start": "next start --port 3001",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:integration": "playwright test --config=playwright.integration.config.ts",
    "openapi-types": "openapi-typescript .atl/api-contract.yaml -o src/lib/api/types.ts --root-types"
  },
  "dependencies": {
    "@core/config": "workspace:*",
    "@core/core": "workspace:*",
    "@core/shared": "workspace:*",
    "@core/ui": "workspace:*",
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.64.2",
    "axios": "^1.7.9",
    "jose": "^5.9.6",
    "lucide-react": "^0.511.0",
    "next": "^15.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.54.2",
    "react-markdown": "^10.1.0",
    "recharts": "^2.15.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tw-animate-css": "^1.2.9",
    "uuid": "^11.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@mswjs/data": "^0.16.2",
    "@playwright/test": "^1.50.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4",
    "eslint": "^9",
    "msw": "^2.6.4",
    "openapi-typescript": "^7.6.1",
    "postcss": "^8",
    "tailwindcss": "^4",
    "typescript": "^5.7.3",
    "vite": "^7.3.1",
    "vitest": "^3.0.5"
  },
  "msw": {
    "workerDirectory": [
      "apps/hub/public"
    ]
  }
}
