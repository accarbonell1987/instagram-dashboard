generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  SuperAdmin
  TenantAdmin
  User

  @@map("user_role")
}

enum UserStatus {
  pending_first_login
  active
  suspended

  @@map("user_status")
}

enum TenantStatus {
  pending
  active
  suspended

  @@map("tenant_status")
}

enum OtpChannel {
  email
  sms

  @@map("otp_channel")
}

enum OtpPurpose {
  login
  first_login  @map("first-login")
  signup_rep   @map("signup-rep")
  recover
  invitation

  @@map("otp_purpose")
}

enum DraftStatus {
  draft
  otp_pending
  otp_verified
  payment_pending
  payment_confirmed
  completed
  expired
  abandoned

  @@map("draft_status")
}

enum DraftStep {
  plan
  representative
  otp
  company
  payment
  summary

  @@map("draft_step")
}

enum PaymentStatus {
  pending
  approved
  declined
  cancelled
  reversed

  @@map("payment_status")
}

enum DocumentType {
  invoice
  contract

  @@map("document_type")
}

enum DocumentStatus {
  pending
  ready
  failed

  @@map("document_status")
}

enum WebhookSource {
  bancard

  @@map("webhook_source")
}

enum PlanChangeRequestStatus {
  pending
  reviewed

  @@map("plan_change_request_status")
}

enum QuestionType {
  multiple_choice
  true_false

  @@map("question_type")
}

enum AttemptStatus {
  in_progress
  completed
  abandoned

  @@map("attempt_status")
}

enum ResourceType {
  deepseek_tokens
  fal_images
  chat_sessions

  @@map("resource_type")
}

enum QuotaPeriod {
  month
  day
  unlimited

  @@map("quota_period")
}

// ============================================================
// CORE TABLES — public schema
// ============================================================

model Plan {
  id              String   @id
  name            String
  description     String?
  price           Decimal  @db.Decimal(12, 2)
  currency        String   @db.VarChar(3)
  billingInterval String   @map("billing_interval")
  maxUsers        Int      @map("max_users")
  features        Json     @default("{}")
  popular         Boolean  @default(false)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenants     Tenant[]
  drafts      OnboardingDraft[]
  planModules PlanModule[]
  quotas      PlanQuota[]

  @@map("plans")
}

model PlanQuota {
  id           String       @id @default(uuid()) @db.Uuid
  planId       String       @map("plan_id")
  resourceType ResourceType @map("resource_type")
  limit        Int
  period       QuotaPeriod  @default(month)
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  plan Plan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, resourceType])
  @@map("plan_quotas")
}

model Tenant {
  id         String       @id @default(uuid()) @db.Uuid
  slug       String       @unique @db.VarChar(40)
  name       String       @db.VarChar(200)
  legalName  String?      @map("legal_name") @db.VarChar(200)
  ruc        String?      @db.VarChar(20)
  address    String?      @db.VarChar(300)
  city       String?      @db.VarChar(100)
  country    String?      @db.VarChar(3)
  phone      String?      @db.VarChar(20)
  schemaName String       @unique @map("schema_name") @db.VarChar(60)
  planId     String       @map("plan_id")
  status     TenantStatus @default(pending)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  plan               Plan              @relation(fields: [planId], references: [id])
  users              User[]
  payments           Payment[]
  documents          Document[]
  invitations        Invitation[]
  drafts             OnboardingDraft[]
  planChangeRequests PlanChangeRequest[]
  moduleOverrides    TenantModuleOverride[]
  quizAttempts       QuizAttempt[]

  @@index([planId])
  @@map("tenants")
}

model User {
  id                  String     @id @default(uuid()) @db.Uuid
  tenantId            String     @map("tenant_id") @db.Uuid
  email               String     @db.VarChar(254)
  passwordHash        String?    @map("password_hash") @db.VarChar(255)
  role                UserRole
  fullName            String?    @map("full_name") @db.VarChar(200)
  phone               String?    @map("phone") @db.VarChar(20)
  picture             String?    @db.VarChar(500)
  status              UserStatus @default(pending_first_login)
  failedLoginAttempts       Int        @default(0) @map("failed_login_attempts")
  lockedUntil               DateTime?  @map("locked_until")
  activationTokenHash       String?    @unique @map("activation_token_hash") @db.VarChar(64)
  activationTokenExpiresAt  DateTime?  @map("activation_token_expires_at")
  activationTokenUsed       Boolean    @default(false) @map("activation_token_used")
  createdAt                 DateTime   @default(now()) @map("created_at")
  updatedAt                 DateTime   @updatedAt @map("updated_at")
  deletedAt                 DateTime?  @map("deleted_at")

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  refreshTokens       RefreshToken[]
  deviceTrusts        DeviceTrust[]
  passwordResetTokens PasswordResetToken[]
  invitationsSent     Invitation[]         @relation("InvitationInviter")
  planChangeRequests  PlanChangeRequest[]  @relation("PlanChangeRequests")

  @@unique([tenantId, email])
  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(64)
  familyId  String    @map("family_id") @db.VarChar(32)
  parentId  String?   @map("parent_id") @db.Uuid
  usedAt    DateTime? @map("used_at")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   RefreshToken?  @relation("TokenRotation", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children RefreshToken[] @relation("TokenRotation")

  @@index([familyId])
  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model DeviceTrust {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  deviceHash String   @map("device_hash") @db.VarChar(64)
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceHash])
  @@index([expiresAt])
  @@map("device_trusts")
}

model OtpCode {
  id          String     @id @default(uuid()) @db.Uuid
  identifier  String     @db.VarChar(254)
  channel     OtpChannel
  purpose     OtpPurpose
  codeHash    String     @map("code_hash") @db.VarChar(60)
  attempts    Int        @default(0)
  used        Boolean    @default(false)
  lockedUntil DateTime?  @map("locked_until")
  expiresAt   DateTime   @map("expires_at")
  createdAt   DateTime   @default(now()) @map("created_at")

  @@index([identifier, purpose, used, expiresAt])
  @@index([expiresAt])
  @@map("otp_codes")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash") @db.VarChar(64)
  used      Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model OnboardingDraft {
  id                   String      @id @default(uuid()) @db.Uuid
  status               DraftStatus @default(draft)
  currentStep          DraftStep   @default(plan) @map("current_step")
  version              Int         @default(0)
  planId               String?     @map("plan_id")
  data                 Json        @default("{}")
  representativeEmail  String?     @map("representative_email") @db.VarChar(254)
  resumeTokenHash      String?     @unique @map("resume_token_hash") @db.VarChar(64)
  resumeTokenExpiresAt DateTime?   @map("resume_token_expires_at")
  resumeTokenUsed      Boolean     @default(false) @map("resume_token_used")
  tenantId             String?     @map("tenant_id") @db.Uuid
  expiresAt            DateTime    @map("expires_at")
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  plan     Plan?     @relation(fields: [planId], references: [id])
  tenant   Tenant?   @relation(fields: [tenantId], references: [id])
  payments Payment[]

  @@index([status, expiresAt])
  @@index([representativeEmail])
  @@map("onboarding_drafts")
}

model Payment {
  id               String        @id @default(uuid()) @db.Uuid
  draftId          String        @map("draft_id") @db.Uuid
  tenantId         String?       @map("tenant_id") @db.Uuid
  bancardProcessId String        @unique @map("bancard_process_id") @db.VarChar(100)
  amount           Decimal       @db.Decimal(12, 2)
  currency         String        @default("PYG") @db.VarChar(3)
  status           PaymentStatus @default(pending)
  reason           String?       @db.VarChar(200)
  initiatedAt      DateTime      @default(now()) @map("initiated_at")
  confirmedAt      DateTime?     @map("confirmed_at")
  createdAt        DateTime      @default(now()) @map("created_at")
  updatedAt        DateTime      @updatedAt @map("updated_at")

  draft  OnboardingDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  tenant Tenant?         @relation(fields: [tenantId], references: [id])

  @@index([draftId, initiatedAt])
  @@map("payments")
}

model WebhookEvent {
  id          String        @id @default(uuid()) @db.Uuid
  source      WebhookSource
  processId   String        @map("process_id") @db.VarChar(100)
  status      String        @db.VarChar(40)
  rawBody     Json          @map("raw_body")
  processedAt DateTime      @default(now()) @map("processed_at")
  createdAt   DateTime      @default(now()) @map("created_at")

  @@unique([processId, status])
  @@index([source, processedAt])
  @@map("webhook_events")
}

model IdempotencyRecord {
  key             String   @id @db.Uuid
  requestHash     String   @map("request_hash") @db.VarChar(64)
  responseStatus  Int      @map("response_status")
  responseBody    Json     @map("response_body")
  responseHeaders Json?    @map("response_headers")
  expiresAt       DateTime @map("expires_at")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("idempotency_records")
}

model Invitation {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @db.VarChar(254)
  tenantId      String    @map("tenant_id") @db.Uuid
  inviterUserId String?   @map("inviter_user_id") @db.Uuid
  role          UserRole  @default(User)
  tokenHash     String    @unique @map("token_hash") @db.VarChar(64)
  usedAt        DateTime? @map("used_at")
  revokedAt     DateTime? @map("revoked_at")
  expiresAt     DateTime  @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  tenant  Tenant @relation(fields: [tenantId], references: [id])
  inviter User?  @relation("InvitationInviter", fields: [inviterUserId], references: [id])

  @@index([email])
  @@index([expiresAt])
  @@map("invitations")
}

model Document {
  id         String         @id @default(uuid()) @db.Uuid
  tenantId   String         @map("tenant_id") @db.Uuid
  type       DocumentType
  storageKey String         @map("storage_key") @db.VarChar(500)
  status     DocumentStatus @default(ready)
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, type])
  @@map("documents")
}

model PlanChangeRequest {
  id          String                  @id @default(uuid()) @db.Uuid
  tenantId    String                  @map("tenant_id") @db.Uuid
  requestedBy String                  @map("requested_by") @db.Uuid
  fromPlanId  String                  @map("from_plan_id")
  toPlanId    String                  @map("to_plan_id")
  status      PlanChangeRequestStatus @default(pending)
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")

  tenant    Tenant @relation(fields: [tenantId], references: [id])
  requester User   @relation("PlanChangeRequests", fields: [requestedBy], references: [id])

  @@index([tenantId, status])
  @@map("plan_change_requests")
}

model Module {
  id          String   @id
  name        String
  description String?
  defaultUrl  String   @map("default_url")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  planModules     PlanModule[]
  tenantOverrides TenantModuleOverride[]
  quizzes         Quiz[]

  @@map("modules")
}

model PlanModule {
  planId   String @map("plan_id")
  moduleId String @map("module_id")
  plan     Plan   @relation(fields: [planId],   references: [id], onDelete: Cascade)
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@id([planId, moduleId])
  @@map("plan_modules")
}

model TenantModuleOverride {
  tenantId  String   @map("tenant_id") @db.Uuid
  moduleId  String   @map("module_id")
  enabled   Boolean
  reason    String?
  createdBy String?  @map("created_by") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, moduleId])
  @@map("tenant_module_overrides")
}

model Quiz {
  id               String     @id @default(uuid()) @db.Uuid
  moduleId         String?    @map("module_id")
  title            String     @db.VarChar(200)
  description      String?    @db.Text
  passingScore     Int        @default(60) @map("passing_score")
  timeLimitMinutes Int?       @map("time_limit_minutes")
  active           Boolean    @default(true)
  createdAt        DateTime   @default(now()) @map("created_at")
  updatedAt        DateTime   @updatedAt @map("updated_at")

  module    Module?         @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  questions Question[]
  attempts  QuizAttempt[]

  @@index([moduleId])
  @@index([active])
  @@map("quizzes")
}

model Question {
  id        String       @id @default(uuid()) @db.Uuid
  quizId    String       @map("quiz_id") @db.Uuid
  text      String       @db.Text
  type      QuestionType
  order     Int          @default(0)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  quiz    Quiz                 @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options QuestionOption[]
  answers QuizAttemptAnswer[]

  @@index([quizId, order])
  @@map("questions")
}

model QuestionOption {
  id         String   @id @default(uuid()) @db.Uuid
  questionId String   @map("question_id") @db.Uuid
  text       String   @db.VarChar(500)
  isCorrect  Boolean  @default(false) @map("is_correct")
  order      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  question Question           @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers  QuizAttemptAnswer[]

  @@index([questionId, order])
  @@map("question_options")
}

model QuizAttempt {
  id          String        @id @default(uuid()) @db.Uuid
  quizId      String        @map("quiz_id") @db.Uuid
  tenantId    String        @map("tenant_id") @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  score       Int?
  passed      Boolean?
  status      AttemptStatus @default(in_progress)
  startedAt   DateTime      @default(now()) @map("started_at")
  completedAt DateTime?     @map("completed_at")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  quiz    Quiz               @relation(fields: [quizId], references: [id], onDelete: Cascade)
  tenant  Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  answers QuizAttemptAnswer[]

  @@index([tenantId, quizId])
  @@index([quizId, userId])
  @@map("quiz_attempts")
}

model QuizAttemptAnswer {
  id               String   @id @default(uuid()) @db.Uuid
  attemptId        String   @map("attempt_id") @db.Uuid
  questionId       String   @map("question_id") @db.Uuid
  selectedOptionId String?  @map("selected_option_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")

  attempt        QuizAttempt    @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       Question       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption QuestionOption? @relation(fields: [selectedOptionId], references: [id], onDelete: SetNull)

  @@unique([attemptId, questionId])
  @@map("quiz_attempt_answers")
}
