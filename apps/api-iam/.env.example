# Server
PORT=8080
NODE_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:3001

# Database
DATABASE_URL=postgresql://corehub:corehub_dev_password@localhost:5432/corehub_iam

# JWT
JWT_PRIVATE_KEY_PATH=./keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt-public.pem
JWT_ACTIVE_KID=key-2026-01
# JWT_PREVIOUS_PUBLIC_KEY_PATH=./keys/jwt-public-prev.pem
# JWT_PREVIOUS_KID=key-2025-12
JWT_ACCESS_TOKEN_TTL_SECONDS=900       # 15 min
JWT_REFRESH_TOKEN_TTL_SECONDS=604800   # 7 days
JWT_ISSUER=https://iam.corehub.com
JWT_AUDIENCE=corehub-hub
JWT_OTP_VERIFICATION_AUDIENCE=otp-verification
JWT_OTP_VERIFICATION_TTL_SECONDS=300

# OTP
OTP_EMAIL_PROVIDER=stub                # stub | smtp | resend
OTP_SMS_PROVIDER=stub                  # stub | twilio
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_LOCKOUT_SECONDS=900
OTP_RESEND_COOLDOWN_SECONDS=30

# Email
EMAIL_PROVIDER=stub                    # stub | smtp | resend
EMAIL_FROM=no-reply@corehub.com
RESEND_API_KEY=                        # required when OTP_EMAIL_PROVIDER=resend or EMAIL_PROVIDER=resend

# SMTP (usado con EMAIL_PROVIDER=smtp o OTP_EMAIL_PROVIDER=smtp)
# En desarrollo: apunta a MailDev en Docker (docker compose up -d)
SMTP_HOST=localhost
SMTP_PORT=1025

# Hub
HUB_BASE_URL=http://localhost:3001     # Base URL of the frontend hub (used for resume links)

# Bancard
BANCARD_PROVIDER=stub                  # stub | real
BANCARD_API_KEY=
BANCARD_API_URL=https://vpos.infonet.com.py
BANCARD_WEBHOOK_SECRET=dev-webhook-secret-long-enough
BANCARD_RETURN_URL=http://localhost:3001/onboarding/payment/return
BANCARD_SHOP_PROCESS_PREFIX=corehub

# PDF
PDF_PROVIDER=stub                      # stub | react-pdf

# Storage
STORAGE_PROVIDER=stub                  # stub | s3
STORAGE_STUB_DIR=/tmp/iam-storage
# AWS_BUCKET=                          # required when STORAGE_PROVIDER=s3
# AWS_REGION=                          # required when STORAGE_PROVIDER=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# TTLs
IDEMPOTENCY_TTL_SECONDS=86400          # 24h
DEVICE_TRUST_TTL_SECONDS=5184000       # 60 days
DRAFT_TTL_SECONDS=604800               # 7 days
RESUME_TOKEN_TTL_SECONDS=604800        # 7 days

# Reserved tenant slugs (comma-separated, no spaces)
RESERVED_TENANT_SLUGS=www,api,app,admin,hub,mail,static,cdn,signup,login,superadmin,__system__

# SuperAdmin seed (used by db:seed only)
SUPERADMIN_EMAIL=admin@corehub.com
SUPERADMIN_PASSWORD=Change-me-in-production!

# Plan change notifications
# PLAN_CHANGE_NOTIFY_TO=plan-changes@corehub.com

# Logging
LOG_LEVEL=info                   # fatal | error | warn | info | debug | trace | silent
LOG_TO_CONSOLE=true              # true | false — mirror logs to stdout
LOG_FILE_PATH=./logs/api-iam.log # path to log file (directory auto-created)
LOG_FORMAT=json                  # json | pretty (pretty only for development)
