{
  "$description": "Shadow tokens - Box shadows for elevation",
  "shadow": {
    "$type": "shadow",
    "sm": {
      "$value": {
        "offsetX": "0",
        "offsetY": "1px",
        "blur": "2px",
        "spread": "0",
        "color": "rgba(0, 0, 0, 0.05)"
      }
    },
    "default": {
      "$value": [
        {
          "offsetX": "0",
          "offsetY": "1px",
          "blur": "3px",
          "spread": "0",
          "color": "rgba(0, 0, 0, 0.1)"
        },
        {
          "offsetX": "0",
          "offsetY": "1px",
          "blur": "2px",
          "spread": "-1px",
          "color": "rgba(0, 0, 0, 0.1)"
        }
      ]
    },
    "md": {
      "$value": [
        {
          "offsetX": "0",
          "offsetY": "4px",
          "blur": "6px",
          "spread": "-1px",
          "color": "rgba(0, 0, 0, 0.1)"
        },
        {
          "offsetX": "0",
          "offsetY": "2px",
          "blur": "4px",
          "spread": "-2px",
          "color": "rgba(0, 0, 0, 0.1)"
        }
      ]
    },
    "lg": {
      "$value": [
        {
          "offsetX": "0",
          "offsetY": "10px",
          "blur": "15px",
          "spread": "-3px",
          "color": "rgba(0, 0, 0, 0.1)"
        },
        {
          "offsetX": "0",
          "offsetY": "4px",
          "blur": "6px",
          "spread": "-4px",
          "color": "rgba(0, 0, 0, 0.1)"
        }
      ]
    },
    "xl": {
      "$value": [
        {
          "offsetX": "0",
          "offsetY": "20px",
          "blur": "25px",
          "spread": "-5px",
          "color": "rgba(0, 0, 0, 0.1)"
        },
        {
          "offsetX": "0",
          "offsetY": "8px",
          "blur": "10px",
          "spread": "-6px",
          "color": "rgba(0, 0, 0, 0.1)"
        }
      ]
    },
    "2xl": {
      "$value": {
        "offsetX": "0",
        "offsetY": "25px",
        "blur": "50px",
        "spread": "-12px",
        "color": "rgba(0, 0, 0, 0.25)"
      }
    },
    "inner": {
      "$value": {
        "offsetX": "0",
        "offsetY": "2px",
        "blur": "4px",
        "spread": "0",
        "color": "rgba(0, 0, 0, 0.05)",
        "inset": true
      }
    },
    "none": {
      "$value": {
        "offsetX": "0",
        "offsetY": "0",
        "blur": "0",
        "spread": "0",
        "color": "transparent"
      }
    }
  }
}
